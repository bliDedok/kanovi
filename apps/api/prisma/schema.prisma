generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. KUMPULAN ENUM (TIPE DATA PILIHAN)
// ==========================================

enum Role {
  OWNER    // Pemilik toko (Dimas / Novi)
  PEGAWAI  // Kasir / Barista / Koki
}

enum Location {
  COUNTER  // Area kasir depan
  KITCHEN  // Area dapur
  BAR      // Area pembuatan minuman
}

// --- BARU: Pemisah Cabang untuk hitung bagi hasil ---
enum Branch {
  PUSAT    // Kanovi Utama
  RESTART  // Kanovi Cabang Kampus (Bagi hasil 25:75)
}

enum PaymentMethod {
  CASH     // Uang tunai (Masuk laci kasir fisik)
  QRIS     // Uang digital (Masuk rekening bank)
}

enum PaymentStatus {
  UNPAID   // Belum dibayar
  PAID     // Sudah dibayar
  VOID     // Dibatalkan/Dihapus
}

enum OrderStatus {
  NEW          // Pesanan baru masuk
  IN_PROGRESS  // Sedang dibuat di dapur/bar
  READY        // Selesai dibuat, siap disajikan
  DONE         // Sudah diselesaikan dari layar antrian
  CANCELED     // Pesanan batal
}

enum StockReason {
  SALE           // Berkurang karena terjual normal
  SALE_OVERRIDE  // Berkurang karena terjual (paksa/override)
  RESTOCK        // Bertambah karena beli bahan baru
  ADJUSTMENT     // Penyesuaian manual (salah hitung)
  SPOIL          // Berkurang karena basi / rusak / tumpah
}

enum PrepStation {
  KITCHEN  // Dikerjakan di dapur
  BAR      // Dikerjakan di bar
}

enum PrepStatus {
  PENDING  // Menunggu dikerjakan
  ACCEPTED // Diterima koki/barista
  STARTED  // Mulai dibuat
  READY    // Selesai dibuat
  SERVED   // Disajikan ke pelanggan
}

enum SessionStatus {
  OPEN     // Toko sedang buka / berjalan
  CLOSED   // Toko sudah tutup / closing selesai
}

// ==========================================
// 2. TABEL MASTER DATA (PENGGUNA & MENU)
// ==========================================

model User {
  id        Int      @id @default(autoincrement()) // ID unik pegawai/owner
  name      String   // Nama lengkap
  username  String   @unique                       // Username untuk login
  password  String   // Password (Hash)
  role      Role     // Jabatan (OWNER / PEGAWAI)
  location  Location // Lokasi kerja default
  orders    Order[]  // Relasi: Pesanan apa saja yang dibuat orang ini
  createdAt DateTime @default(now())               // Waktu akun dibuat
  updatedAt DateTime @updatedAt                    // Waktu akun terakhir diedit
}

model Category {
  id        Int      @id @default(autoincrement()) // ID kategori
  name      String   // Nama (Kopi, Teh, Makanan)
  slug      String   @unique                       // URL ramah (kopi, teh, dll)
  isActive  Boolean  @default(true)                // Muncul di menu atau tidak?
  sortOrder Int      @default(0)                   // Urutan tampil
  menus     Menu[]   // Relasi: Daftar menu di dalam kategori ini
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Menu {
  id          Int         @id @default(autoincrement())
  name        String      // Nama makanan/minuman
  price       Int         // Harga jual
  categoryId  Int?        // ID kategori (bisa kosong)
  prepStation PrepStation @default(KITCHEN) // Dibuat di Bar atau Kitchen?

  category    Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  recipes     Recipe[]      // Relasi: Resep bahan baku yang dibutuhkan
  details     OrderDetail[] // Relasi: Pernah dipesan di struk mana saja

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Ingredient {
  id        Int             @id @default(autoincrement())
  name      String          // Nama bahan (Gula, Kopi, Susu)
  stock     Int             @default(0) // Sisa stok saat ini
  unit      String          // Satuan (gram, ml, pcs)
  minStock  Int             // Batas minimal sebelum muncul peringatan "Low Stock"
  
  recipes   Recipe[]        // Relasi: Dipakai di menu apa saja
  movements StockMovement[] // Relasi: Riwayat keluar-masuk barang

  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([name])
  @@index([stock])
  @@index([minStock])
}

// Tabel penghubung: Menu A butuh Bahan B sebanyak C
model Recipe {
  id           Int        @id @default(autoincrement())
  menuId       Int        // ID Menu
  ingredientId Int        // ID Bahan
  amountNeeded Int        // Jumlah yang dipotong setiap kali menu terjual

  menu         Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([menuId, ingredientId]) // Mencegah 1 menu punya 2 resep bahan yang sama
}

// ==========================================
// 3. TABEL TRANSAKSI (ORDER & STOK)
// ==========================================

model Order {
  id            Int            @id @default(autoincrement()) 
  userId        Int            
  origin        Location       
  customerName  String?        
  
  // --- BINDING KE FINANCE ---
  sessionId     Int?           // ID Sesi Kasir
  session       CashSession?   @relation(fields: [sessionId], references: [id])
  branch        Branch         @default(PUSAT) 

  paymentMethod PaymentMethod? 
  paymentStatus PaymentStatus  @default(UNPAID) 
  status        OrderStatus    @default(NEW)    

  totalPrice    Int            @default(0)      
  orderedAt     DateTime       @default(now())  
  paidAt        DateTime?      

  stockOverride Boolean        @default(false)  
  overrideNote  String?        

  user          User           @relation(fields: [userId], references: [id])
  details       OrderDetail[] 
  stockMovements StockMovement[] 

  @@index([orderedAt])
  @@index([paymentStatus])
  @@index([status])
  @@index([userId])
  @@index([sessionId])
}

model OrderDetail {
  id          Int         @id @default(autoincrement())
  orderId     Int         // Nomor struk
  menuId      Int         // ID Menu yang dibeli
  qty         Int         // Jumlah beli (2 es kopi)
  price       Int         // Harga satuan saat itu
  subtotal    Int         // qty * price

  prepStation PrepStation @default(KITCHEN) // Dilempar ke Bar/Kitchen
  prepStatus  PrepStatus  @default(PENDING) // Status pembuatan per item

  acceptedAt  DateTime?   // Waktu mulai dikerjakan
  startedAt   DateTime?   // Waktu sedang diproses
  readyAt     DateTime?   // Waktu selesai dibuat
  servedAt    DateTime?   // Waktu diambil pelanggan

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menu        Menu        @relation(fields: [menuId], references: [id])

  @@index([orderId])
  @@index([prepStation, prepStatus])
}

// Riwayat keluar-masuk stok barang
model StockMovement {
  id           Int         @id @default(autoincrement())
  ingredientId Int         // Barang apa yang bergerak
  qtyChange    Int         // Minus (-) kalau keluar, Plus (+) kalau masuk
  reason       StockReason // Kenapa bergerak (Sale, Spoil, Restock)
  orderId      Int?        // Kosong jika bukan karena terjual
  createdAt    DateTime    @default(now())

  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  order        Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([ingredientId])
}

// ==========================================
// 4. BARU: TABEL MANAJEMEN KEUANGAN (CASH CLOSING)
// ==========================================

// Mencatat Buka-Tutup Toko / Sesi Kasir Harian
model CashSession {
  id           Int           @id @default(autoincrement())
  branch       Branch        // Sesi ini untuk cabang mana? (Pusat / Restart)
  
  openedBy     String        // Nama yang buka toko (Cukup diketik: "Dimas" / "Novi")
  openedAt     DateTime      @default(now()) // Jam buka toko
  initialCash  Int           // Modal awal di laci (kembalian)
  
  status       SessionStatus @default(OPEN)  // Masih jalan atau sudah tutup?
  
  closedBy     String?       // Nama yang closing toko
  closedAt     DateTime?     // Jam tutup toko
  
  // Perhitungan Kasir (Hanya diisi saat Closing)
  expectedCash Int?          // Uang laci seharusnya (Modal + Total Pembayaran CASH)
  actualCash   Int?          // Uang fisik yang dihitung nyata saat malam
  difference   Int?          // Selisih (actual - expected). Minus berarti hilang/nombok
  note         String?       // Catatan selisih ("hilang 5rb ga tau kemana")

  orders       Order[]       // Semua struk pesanan yang masuk selama sesi ini
  expenses     Expense[]     // Semua pengeluaran dadakan selama sesi ini

  @@index([status])
  @@index([branch])
}

// Mencatat Pengeluaran Dadakan (Beli es batu, galon, dll)
model Expense {
  id           Int          @id @default(autoincrement())
  sessionId    Int          // Masuk di sesi kasir yang mana
  branch       Branch       // Pengeluaran untuk cabang mana
  
  amount       Int          // Nominal pengeluaran
  description  String       // Keterangan (Contoh: "Beli gas elpiji")
  recordedBy   String       // Siapa yang input (Contoh: "Dimas")
  createdAt    DateTime     @default(now())

  session      CashSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}