{
  "name": "kanovi-pos",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
  "dev": "pnpm -r --if-present dev",
  "postinstall": "pnpm --filter api prisma generate",
  "build": "pnpm -r --if-present build",
  "lint": "pnpm -r --if-present lint",
  "format": "prettier -w .",
  "db:up": "docker compose up -d",
  "db:down": "docker compose down",
  "db:migrate": "pnpm --filter api prisma migrate dev",
  "db:studio": "pnpm --filter api prisma studio",
  "seed": "cd apps/api && pnpm tsx prisma/seed.ts",
  "reset": "pnpm --filter api prisma migrate reset --schema ./prisma/schema.prisma"
},
  "devDependencies": {
    "prettier": "^3.3.3"
  }
}